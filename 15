local function makeSlider(parent, label, value)
	local holder = Instance.new("Frame")
	holder.Size = UDim2.new(1, 0, 0, 52)
	holder.BackgroundColor3 = Color3.fromRGB(21, 24, 37)
	holder.Active = false
	holder.Selectable = false
	holder.Parent = parent

	corner(holder, 8)
	stroke(holder, Color3.fromRGB(75, 83, 125), 1, 0.78)

	local l = text(holder, label .. "  " .. value .. "%", 12, false)
	l.Position = UDim2.new(0, 12, 0, 4)
	l.Size = UDim2.new(1, -24, 0, 22)

	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(1, -24, 0, 6)
	bar.Position = UDim2.new(0, 12, 0, 35)
	bar.BackgroundColor3 = Color3.fromRGB(45, 49, 70)
	bar.Active = false
	bar.Selectable = false
	bar.Parent = holder

	corner(bar, 99)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(value / 100, 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(100, 105, 255)
	fill.Active = false
	fill.Selectable = false
	fill.Parent = bar

	corner(fill, 99)

	return holder
end

