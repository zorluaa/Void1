local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local SPIN_SPEED = 12 -- higher = faster

local spinConnection

local function startSpinning(character)
	local humanoid = character:WaitForChild("Humanoid")
	local root = character:WaitForChild("HumanoidRootPart")

	humanoid.AutoRotate = false

	if spinConnection then
		spinConnection:Disconnect()
	end

	spinConnection = RunService.RenderStepped:Connect(function(deltaTime)
		if root and root.Parent then
			root.CFrame = root.CFrame * CFrame.Angles(0, SPIN_SPEED * deltaTime, 0)
		end
	end)
end

if player.Character then
	startSpinning(player.Character)
end

player.CharacterAdded:Connect(startSpinning)
