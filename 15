-- Robust client-side mute
local mutedVolumes = {}

local function muteSound(sound)
	if sound:IsA("Sound") then
		if mutedVolumes[sound] == nil then
			mutedVolumes[sound] = sound.Volume
		end
		sound.Volume = 0
	end
end

for _, obj in ipairs(game:GetDescendants()) do
	muteSound(obj)
end

game.DescendantAdded:Connect(function(obj)
	muteSound(obj)
end)

