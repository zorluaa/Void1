-- Final safety pass: make every GUI object visible but non-interactive
local function makeEntireGuiUnclickable(root)
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("GuiObject") then
			obj.Active = false
			obj.Selectable = false
		end

		if obj:IsA("GuiButton") then
			obj.AutoButtonColor = false
		end
	end
end

