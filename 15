local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
end

local function stroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness
	s.Transparency = transparency or 0
	s.Parent = parent
end

local function gradient(parent, c1, c2)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, c1),
		ColorSequenceKeypoint.new(1, c2)
	})
	g.Rotation = 25
	g.Parent = parent
end

local function text(parent, content, size, bold)
	local t = Instance.new("TextLabel")
	t.BackgroundTransparency = 1
	t.Text = content
	t.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
	t.TextSize = size
	t.TextColor3 = Color3.fromRGB(235, 238, 255)
	t.TextXAlignment = Enum.TextXAlignment.Left
	t.TextYAlignment = Enum.TextYAlignment.Center
	t.TextTruncate = Enum.TextTruncate.AtEnd
	t.Active = false
	t.Selectable = false
	t.Parent = parent
	return t
end

-- Fake visual button, NOT clickable
local function makeButton(parent, label)
	local b = Instance.new("TextLabel")
	b.Size = UDim2.new(1, 0, 0, 38)
	b.BackgroundColor3 = Color3.fromRGB(24, 27, 42)
	b.Text = label
	b.Font = Enum.Font.GothamMedium
	b.TextSize = 13
	b.TextColor3 = Color3.fromRGB(225, 228, 245)
	b.TextXAlignment = Enum.TextXAlignment.Center
	b.TextYAlignment = Enum.TextYAlignment.Center
	b.Active = false
	b.Selectable = false
	b.Parent = parent

	corner(b, 8)
	stroke(b, Color3.fromRGB(80, 88, 130), 1, 0.72)

	return b
end

-- Fake visual toggle, NOT clickable
local function makeToggle(parent, label)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 38)
	row.BackgroundColor3 = Color3.fromRGB(21, 24, 37)
	row.Active = false
	row.Selectable = false
	row.Parent = parent

	corner(row, 8)
	stroke(row, Color3.fromRGB(75, 83, 125), 1, 0.78)

	local l = text(row, label, 12, false)
	l.Position = UDim2.new(0, 12, 0, 0)
	l.Size = UDim2.new(1, -70, 1, 0)

